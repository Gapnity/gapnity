# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: anthropic | openai | groq | mock (default)
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / OpenAI-compatible
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Groq (free tier, fast)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use in-memory fixtures (default for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/gapnity

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend URL (used for OAuth redirects) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Jira OAuth 2.0 (3LO) ─────────────────────────────────────────────────────
# 1. Go to https://developer.atlassian.com/console/myapps/
# 2. Create an OAuth 2.0 (3LO) app
# 3. Add the callback URL below under "Callback URLs"
# 4. Grant scopes: read:jira-work  read:jira-user  write:jira-work  offline_access
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/integrations/jira/callback
